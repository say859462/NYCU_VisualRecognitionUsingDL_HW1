{
  "batch_size": 16,
  "num_epochs": 25,
  "learning_rate": 5e-5,
  "num_classes": 100,
  "data_dir": "./Dataset/data",

  "checkpoint_path": "./Model_Weight/checkpoint.pth",
  "best_pmg_model_path": "./Model_Weight/best_pmg_model.pth",
  "best_model_path": "./Model_Weight/best_model.pth",
  "best_loss_model_path": "./Model_Weight/best_loss_model.pth",

  "resume_training": false,
  "early_stopping_patience": 30,

  "num_subcenters": 1,
  "embed_dim": 256,
  "proto_diversity_weight": 0.0,

  "pmg_stage1_epochs": 4,
  "pmg_stage2_epochs": 4,

  "pmg_stage1_global_weight": 1.0,

  "pmg_stage2_global_weight": 1.0,
  "pmg_stage2_part2_weight": 0.5,
  "pmg_stage2_part4_weight": 0.0,
  "pmg_stage2_concat_weight": 0.5,
  "pmg_stage2_fusion_weight": 0.0,

  "pmg_stage3_global_weight": 1.0,
  "pmg_stage3_part2_weight": 0.5,
  "pmg_stage3_part4_weight": 0.5,
  "pmg_stage3_concat_weight": 1.0,
  "pmg_stage3_fusion_weight": 0.0,

  "enable_fusion_refine": false,
  "fusion_refine_epochs": 0,
  "fusion_refine_lr": 2e-5,
  "fusion_refine_checkpoint_path": "./Model_Weight/best_pmg_model.pth",

  "fusion_init_weights": {
    "global": 0.15,
    "part2": 0.25,
    "part4": 0.1,
    "concat": 0.5
  }
}
